<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.drone.repository.UserRepository">
    <resultMap id="userMap" type="com.example.drone.domain.entity.SysUser">
        <id property="id" column="id"/>
        <result property="email" column="email"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="status" column="status"/>
        <result property="role" column="role"/>
        <result property="activationToken" column="activation_token"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user (email, password_hash, status, role, activation_token) VALUES (#{email}, #{passwordHash}, #{status}, #{role}, #{activationToken})
    </insert>
    <select id="selectById" resultMap="userMap">SELECT * FROM sys_user WHERE id = #{id}</select>
    <select id="selectByEmail" resultMap="userMap">SELECT * FROM sys_user WHERE email = #{email}</select>
    <update id="updateStatus">UPDATE sys_user SET status = #{status} WHERE id = #{id}</update>
    <update id="updatePassword">UPDATE sys_user SET password_hash = #{passwordHash} WHERE id = #{id}</update>
    <update id="updateActivationToken">UPDATE sys_user SET activation_token = #{token} WHERE id = #{id}</update>
    <select id="selectByActivationToken" resultMap="userMap">SELECT * FROM sys_user WHERE activation_token = #{token}</select>
    <insert id="insertUserRole">
        INSERT INTO sys_user_role (user_id, role_id) VALUES (#{userId}, #{roleId})
    </insert>
    <delete id="deleteUserRoles">DELETE FROM sys_user_role WHERE user_id = #{userId}</delete>
    <delete id="deleteById">DELETE FROM sys_user WHERE id = #{id}</delete>
</mapper>
